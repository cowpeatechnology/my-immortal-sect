  "session": {
    "target_seconds": 600,
    "first_raid_prep_seconds": 24,
    "phase_order": [
      "clear_ruin",
      "place_guard_tower",
      "upgrade_guard_tower",
      "raid_countdown",
      "defend",
      "recover",
      "second_cycle_ready",
      "victory",
      "defeat"
    ],
    "phase_rules": [
      {
        "runtime_key": "clear_ruin",
        "objective": "长按废弃仓房并拆除，为护山台腾出位置",
        "enter_when": "initial_ruin remains in the authoritative building set",
        "next_phase_hint": "place_guard_tower"
      },
      {
        "runtime_key": "place_guard_tower",
        "objective": "在空地上放下第一座护山台",
        "enter_when": "initial_ruin is removed and no guard tower exists",
        "next_phase_hint": "upgrade_guard_tower"
      },
      {
        "runtime_key": "upgrade_guard_tower",
        "objective": "把护山台升到 Lv.2，为首波敌袭做准备",
        "enter_when": "guard tower exists but is not yet active at level 2",
        "next_phase_hint": "raid_countdown"
      },
      {
        "runtime_key": "raid_countdown",
        "objective": "护山台已就位，准备迎接第一波敌袭",
        "enter_when": "guard tower is active at level 2 and the first raid is not yet triggered",
        "next_phase_hint": "defend"
      },
      {
        "runtime_key": "defend",
        "objective": "守住首波敌袭，不要让主殿瘫痪",
        "enter_when": "first raid has been triggered and not yet resolved",
        "next_phase_hint": "recover"
      },
      {
        "runtime_key": "recover",
        "objective": "首波敌袭已退去，修复受损建筑并恢复运转",
        "enter_when": "first raid is resolved and at least one building still needs repair",
        "next_phase_hint": "recover"
      },
      {
        "runtime_key": "recover",
        "objective": "首波敌袭已守住，等待采空资源点恢复后进入下一轮筹备",
        "enter_when": "all damaged buildings are repaired but at least one resource node is still regenerating",
        "next_phase_hint": "second_cycle_ready"
      },
      {
        "runtime_key": "second_cycle_ready",
        "objective": "资源点与库存保持当前 authority 状态，可继续准备下一轮",
        "enter_when": "all damaged buildings are repaired and no resource node is regenerating",
        "next_phase_hint": "raid_countdown"
      },
      {
        "runtime_key": "victory",
        "objective": "短会话目标完成",
        "enter_when": "session target time is reached while the main hall remains operational"
      },
      {
        "runtime_key": "defeat",
        "objective": "短会话失败，请重新开局再试",
        "enter_when": "session target expires in a failed state or the main hall is destroyed"
      }
    ]
  }
}
