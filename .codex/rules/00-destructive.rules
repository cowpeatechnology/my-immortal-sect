# Never allow destructive workspace rewrites for this planning-stage project.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard work in this repository with git reset --hard. Inspect and patch surgically instead.",
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "forbidden",
    justification = "Do not discard tracked file changes with git checkout --. Read the file and patch the exact lines instead.",
)

prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "forbidden",
    justification = "Do not delete untracked files in this repository. The workspace is still in planning and contains supporting assets and docs.",
)

prefix_rule(
    pattern = ["git", "clean", "-fdx"],
    decision = "forbidden",
    justification = "Do not delete untracked or ignored files in this repository.",
)

prefix_rule(
    pattern = ["rm", "-rf", "tools"],
    decision = "forbidden",
    justification = "tools/ is protected. Change it only during explicit tooling tasks.",
)

prefix_rule(
    pattern = ["rm", "-rf", "./tools"],
    decision = "forbidden",
    justification = "tools/ is protected. Change it only during explicit tooling tasks.",
)

prefix_rule(
    pattern = ["rm", "-rf", "hifi-prototype"],
    decision = "forbidden",
    justification = "hifi-prototype/ is protected. Change it only during explicit prototype tasks.",
)

prefix_rule(
    pattern = ["rm", "-rf", "./hifi-prototype"],
    decision = "forbidden",
    justification = "hifi-prototype/ is protected. Change it only during explicit prototype tasks.",
)
